model Organization {
  id          String    @id @default(uuid())
  name        String
  description String?
  logo        String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  employees Employee[]
  clients   OrganizationClient[]
  services  Service[]
  positions Position[]

  @@map("organizations")
}
