model Permission {
  id        String     @id @default(uuid())
  name      String
  description String?
  value     String     @unique
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  deletedAt DateTime?  @map("deleted_at")

  positions Position[]

  @@map("permissions")
}
